@font-face {
  font-family: 'Material Symbols Filled Local';
  src: url("data:font/truetype;charset=utf-8;base64,") format('truetype');
  font-weight: 400;
  font-style: normal;
}

@font-face {
  font-family: 'Material Symbols Outlined Local';
  src: url("data:font/truetype;charset=utf-8;base64,") format('truetype');
  font-weight: 400;
  font-style: normal;
}

.material-symbols-filled,
.material-symbols-outlined {
  display: inline-block;
  font-style: normal;
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0;
  text-transform: none;
  white-space: nowrap;
  word-wrap: normal;
}

.material-symbols-filled {
  font-family: 'Material Symbols Filled Local';
}

.material-symbols-outlined {
  font-family: 'Material Symbols Outlined Local';
}