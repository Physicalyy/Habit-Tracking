<view class="custom-tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="{{item.className}}"
    data-index="{{index}}"
    bindtap="switchTab"
    hover-class="tab-item-pressed"
  >
    <text class="material-symbols-outlined tab-icon">{{item.icon}}</text>
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
