@import "/assets/fonts/material-symbols.wxss";

.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16rpx 48rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 30rpx rgba(0, 107, 88, 0.05);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  min-height: 76rpx;
  padding: 8rpx 24rpx;
  color: #6e7a75;
  border-radius: 999rpx;
  transition: transform 0.16s ease, background-color 0.16s ease;
}

.tab-item-active {
  color: #005d4c;
  background: #76d6bc;
}

.tab-item-pressed {
  transform: scale(0.94);
}

.tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-label {
  margin-top: 2rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 30rpx;
}
