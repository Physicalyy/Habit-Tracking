<view class="page today-page">
  <view class="top-bar today-top">
    <view class="icon-button">‹</view>
    <view class="top-title">{{childNickname}} 今日打卡</view>
    <view class="icon-button">›</view>
  </view>

  <view wx:if="{{loading}}" class="muted-text today-state">加载中...</view>
  <view wx:elif="{{errorText}}" class="error-text today-state">{{errorText}}</view>

  <view wx:elif="{{todayHabits.length === 0}}" class="empty-card">
    <view class="empty-art float-animation">
      <image class="empty-image" mode="aspectFit" src="/assets/onboarding/today-empty-sprout.png" />
    </view>
    <view class="empty-title">还没有配置习惯</view>
    <view class="empty-desc">先从习惯库添加适合孩子的习惯</view>
    <view class="primary-button empty-action" bindtap="goHabitLibrary">去配置习惯</view>
  </view>

  <view wx:else class="today-list">
    <view wx:for="{{todayHabits}}" wx:key="childHabitId" class="today-habit-card card">
      <view class="habit-icon">
        <image wx:if="{{item.imageUrl}}" class="habit-image" mode="aspectFill" src="{{item.imageUrl}}" />
        <text wx:else>{{item.fallbackIcon}}</text>
      </view>
      <view class="habit-main">
        <view class="habit-name">{{item.name}}</view>
        <view class="habit-desc">{{item.description}}</view>
        <view class="habit-meta">
          <text>{{item.checkedText}}</text>
          <text class="{{item.canCheckin ? 'permission-ok' : 'permission-deny'}}">{{item.permissionText}}</text>
        </view>
      </view>
      <view
        class="checkin-action {{item.actionDisabled ? 'checkin-action-disabled' : ''}}"
        data-habit-id="{{item.childHabitId}}"
        bindtap="checkinTap"
      >
        {{item.actionText}}
      </view>
    </view>
  </view>
</view>
