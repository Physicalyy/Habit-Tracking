.today-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx 24rpx 150rpx;
}

.empty-card {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 92rpx;
  text-align: center;
}

.empty-art {
  position: relative;
  width: 432rpx;
  height: 432rpx;
  margin-bottom: 30rpx;
}

.empty-image {
  display: block;
  width: 100%;
  height: 100%;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.empty-desc {
  margin-top: 12rpx;
  color: #3e4945;
  font-size: 28rpx;
  line-height: 42rpx;
}

.empty-action {
  width: 344rpx;
  margin-top: 38rpx;
}
