.today-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 24rpx 210rpx;
  padding-bottom: calc(210rpx + env(safe-area-inset-bottom));
}

.today-top {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 40;
  padding-left: 24rpx;
  padding-right: 24rpx;
  background: #f8faf8;
}

.today-top .nav-content {
  display: flex;
  align-items: center;
}

.today-state {
  margin-top: 40rpx;
  text-align: center;
}

.empty-card {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 52rpx 0 96rpx;
  text-align: center;
}

.empty-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 512rpx;
  height: 512rpx;
  margin-bottom: 48rpx;
}

.floating-anim {
  animation: floating 3s ease-in-out infinite;
}

.empty-orbit,
.empty-orbit-inner {
  position: absolute;
  left: 50%;
  top: 50%;
  background: #94f4d9;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.empty-orbit {
  width: 512rpx;
  height: 512rpx;
  opacity: 0.1;
  transform: translate(-50%, -50%) scale(1.1);
}

.empty-orbit-inner {
  width: 384rpx;
  height: 384rpx;
  opacity: 0.2;
  animation: empty-pulse 2s ease-in-out infinite;
  transform: translate(-50%, -50%) scale(0.75);
}

.empty-image-shell {
  position: relative;
  z-index: 1;
  width: 384rpx;
  height: 384rpx;
  overflow: hidden;
  border-radius: 999rpx;
}

.empty-image {
  display: block;
  width: 384rpx;
  height: 384rpx;
}

.empty-title {
  color: #191c1b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 60rpx;
}

.empty-desc {
  margin-top: 16rpx;
  color: #3e4945;
  font-size: 30rpx;
  line-height: 44rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(100% - 48rpx);
  max-width: 640rpx;
  height: 112rpx;
  margin-top: 64rpx;
  border-radius: 24rpx;
  line-height: 112rpx;
  background: linear-gradient(180deg, #006b58 0%, #005d4c 100%);
}

.empty-action-icon {
  margin-right: 16rpx;
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1;
}

.empty-action-pressed {
  transform: scale(0.96);
}

@keyframes floating {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-20rpx);
  }
}

@keyframes empty-pulse {
  0%,
  100% {
    opacity: 0.2;
    transform: translate(-50%, -50%) scale(0.75);
  }

  50% {
    opacity: 0.3;
    transform: translate(-50%, -50%) scale(0.79);
  }
}

.today-list {
  margin-top: 32rpx;
}

.today-hero {
  display: flex;
  align-items: flex-end;
  margin-bottom: 32rpx;
}

.today-date {
  color: #56625d;
  font-size: 26rpx;
  line-height: 38rpx;
}

.today-heading {
  margin-top: 4rpx;
  color: #191c1b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.progress-card {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 40rpx;
}

.progress-ring {
  display: flex;
  flex: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 192rpx;
  height: 192rpx;
  background: radial-gradient(circle, #ffffff 0 57%, transparent 58%), conic-gradient(#006b58 0%, #006b58 0%, #f2f4f2 0%, #f2f4f2 100%);
  border-radius: 999rpx;
}

.progress-percent {
  color: #006b58;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.progress-label {
  color: #6e7a75;
  font-size: 22rpx;
  line-height: 30rpx;
}

.progress-copy {
  flex: 1;
  min-width: 0;
  margin-left: 36rpx;
}

.progress-title {
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.progress-desc {
  margin-top: 8rpx;
  color: #56625d;
  font-size: 26rpx;
  line-height: 38rpx;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.section-link {
  color: #006b58;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.today-habit-card {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 26rpx;
  border-left: 8rpx solid #76d6bc;
}

.checkin-card-checking {
  transform: scale(0.985);
  transition: transform 120ms ease-out;
}

.checkin-card-success {
  overflow: hidden;
  animation: checkin-card-pop 420ms ease-out both;
  box-shadow: 0 18rpx 48rpx rgba(0, 107, 88, 0.14);
}

.checkin-card-leaving {
  animation: checkin-card-leave 280ms ease-in both;
}

.checkin-success-burst {
  position: absolute;
  right: 48rpx;
  top: 50%;
  width: 96rpx;
  height: 96rpx;
  pointer-events: none;
  transform: translateY(-50%);
}

.checkin-success-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(0, 107, 88, 0.22);
  border-radius: 999rpx;
  animation: checkin-burst-pop 520ms ease-out both;
  transform: translate(-50%, -50%);
}

.checkin-particle {
  position: absolute;
  left: 44rpx;
  top: 44rpx;
  width: 10rpx;
  height: 10rpx;
  background: #76d6bc;
  border-radius: 999rpx;
  animation: checkin-particle-pop 620ms ease-out both;
}

.checkin-particle-1 {
  animation-name: checkin-particle-pop-1;
}

.checkin-particle-2 {
  background: #006b58;
  animation-name: checkin-particle-pop-2;
}

.checkin-particle-3 {
  background: #9ee5d1;
  animation-name: checkin-particle-pop-3;
}

.checkin-particle-4 {
  animation-name: checkin-particle-pop-4;
}

@keyframes checkin-card-pop {
  0% {
    transform: scale(0.985);
  }

  45% {
    transform: scale(1.018);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes checkin-card-leave {
  0% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  100% {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }
}

@keyframes checkin-burst-pop {
  0% {
    opacity: 0.72;
    transform: translate(-50%, -50%) scale(0.55);
  }

  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.35);
  }
}

@keyframes checkin-particle-pop-1 {
  0% {
    opacity: 0;
    transform: translate(0, 0) scale(0.4);
  }

  35% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translate(-34rpx, -30rpx) scale(1);
  }
}

@keyframes checkin-particle-pop-2 {
  0% {
    opacity: 0;
    transform: translate(0, 0) scale(0.4);
  }

  35% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translate(32rpx, -28rpx) scale(1);
  }
}

@keyframes checkin-particle-pop-3 {
  0% {
    opacity: 0;
    transform: translate(0, 0) scale(0.4);
  }

  35% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translate(-28rpx, 30rpx) scale(1);
  }
}

@keyframes checkin-particle-pop-4 {
  0% {
    opacity: 0;
    transform: translate(0, 0) scale(0.4);
  }

  35% {
    opacity: 1;
  }

  100% {
    opacity: 0;
    transform: translate(34rpx, 28rpx) scale(1);
  }
}

.checked-section {
  margin-top: 24rpx;
}

.checked-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #eef7f3;
  border: 2rpx solid #d7eee5;
  border-radius: 24rpx;
}

.checked-section-copy {
  flex: 1;
  min-width: 0;
}

.checked-section-title {
  color: #26322e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.checked-section-hint {
  margin-top: 4rpx;
  color: #6e7a75;
  font-size: 22rpx;
  line-height: 32rpx;
}

.checked-section-toggle {
  display: flex;
  flex: none;
  align-items: center;
  margin-left: 24rpx;
  color: #006b58;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.checked-section-icon {
  margin-left: 4rpx;
  color: #006b58;
  font-size: 32rpx;
  line-height: 1;
}

.checked-habit-list {
  margin-top: 16rpx;
}

.checked-habit-card {
  border-left-color: #d7eee5;
  opacity: 0.82;
}

.checked-habit-icon {
  background: #f3f6f4;
}

.habit-icon {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: #006b58;
  background: #e6f7f1;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.habit-image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
}

.habit-main {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.habit-title-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.habit-name {
  max-width: 100%;
  overflow: hidden;
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.habit-name-checked {
  color: #56625d;
  text-decoration: line-through;
}

.source-badge {
  flex: none;
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  color: #574500;
  background: #ffe088;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.source-badge-custom {
  color: #574500;
  background: #ffe088;
}

.habit-desc {
  margin-top: 6rpx;
  color: #56625d;
  font-size: 24rpx;
  line-height: 34rpx;
}

.permission-inline-text {
  flex: none;
  max-width: 180rpx;
  margin-left: 18rpx;
  color: #6e7a75;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: right;
}

.checkin-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  margin-left: 18rpx;
  padding: 18rpx 24rpx;
  color: #005d4c;
  background: #76d6bc;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.undo-checkin-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  margin-left: 18rpx;
  padding: 16rpx 22rpx;
  color: #7c2d12;
  background: #fff1e8;
  border: 2rpx solid rgba(186, 26, 26, 0.14);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.checkin-action-checking {
  color: #006b58;
  background: #d9f7ee;
}

.checkin-action-success {
  color: #ffffff;
  background: #006b58;
  animation: checkin-action-pop 360ms ease-out both;
}

.checkin-action-disabled {
  color: #7d8782;
  background: #eef1ef;
}

.checkin-action-icon {
  margin-right: 6rpx;
  color: #006b58;
  font-size: 28rpx;
  line-height: 1;
}

.checkin-action-success .checkin-action-icon {
  color: #ffffff;
}

@keyframes checkin-action-pop {
  0% {
    transform: scale(0.86);
  }

  60% {
    transform: scale(1.08);
  }

  100% {
    transform: scale(1);
  }
}
