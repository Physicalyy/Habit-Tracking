.family-invite-page {
  padding-bottom: 56rpx;
}

.invite-state {
  margin-top: 36rpx;
  text-align: center;
}

.empty-card {
  margin-top: 28rpx;
  padding: 36rpx;
}

.empty-title {
  color: #191c1b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.invite-family-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 34rpx;
  text-align: center;
}

.family-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  color: #005d4c;
  background: #78d8be;
  border-radius: 999rpx;
  font-size: 64rpx;
  line-height: 1;
}

.invite-family-name {
  margin-top: 18rpx;
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.invite-code-card,
.qr-card {
  margin-top: 30rpx;
  padding: 28rpx;
  background: #ffffff;
  border-left: 8rpx solid #006b58;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 107, 88, 0.05);
}

.qr-card {
  border-left-color: #735c00;
}

.card-label {
  display: flex;
  align-items: center;
  color: #3e4945;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.card-label-icon {
  margin-right: 8rpx;
  color: #006b58;
  font-size: 28rpx;
  line-height: 1;
}

.code-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.invite-code {
  flex: 1;
  min-width: 0;
  padding: 24rpx 18rpx;
  color: #005d4c;
  background: #f2f4f2;
  border: 2rpx dashed #bdc9c4;
  border-radius: 14rpx;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  line-height: 54rpx;
  text-align: center;
}

.copy-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  min-width: 166rpx;
  height: 104rpx;
  margin-left: 18rpx;
  color: #ffffff;
  background: #006b58;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.refresh-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
}

.refresh-hint {
  flex: 1;
  min-width: 0;
  margin-right: 18rpx;
  color: #56625d;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 32rpx;
}

.refresh-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  min-width: 168rpx;
  height: 64rpx;
  padding: 0 22rpx;
  color: #006b58;
  background: #ffffff;
  border: 2rpx solid #006b58;
  border-radius: 16rpx;
  margin-top: 18rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.refresh-row .refresh-button {
  margin-top: 0;
}

.action-disabled {
  opacity: 0.48;
}

.refresh-icon {
  margin-right: 8rpx;
  font-size: 26rpx;
  line-height: 1;
}

.qr-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 360rpx;
  height: 360rpx;
  margin: 28rpx auto 18rpx;
  background: #ffffff;
  border: 2rpx solid #bdc9c4;
  border-radius: 16rpx;
}

.qr-canvas {
  width: 220px;
  height: 220px;
}

.invite-footer-hint {
  display: flex;
  align-items: flex-start;
  margin-top: 30rpx;
  padding: 0 18rpx;
  color: #56625d;
  font-size: 22rpx;
  line-height: 34rpx;
}

.footer-info {
  flex: none;
  margin-right: 10rpx;
  color: #735c00;
  font-size: 26rpx;
  line-height: 1;
}
