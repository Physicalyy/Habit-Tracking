<view class="page me-page">
  <view class="profile-card card">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-info">
      <view class="profile-name">{{nickname}}</view>
      <view class="profile-family muted-text">{{familyName}}</view>
      <view class="profile-child muted-text">默认孩子：{{childNickname}}</view>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="goFamilyMembers">
      <text>家庭成员</text>
      <text class="muted-text">{{hasFamily ? "去查看" : "未加入"}}</text>
    </view>
    <view class="menu-item {{isFamilyAdmin ? '' : 'menu-item-disabled'}}" bindtap="goFamilyInvite">
      <text>邀请码</text>
      <text class="muted-text">{{isFamilyAdmin ? "去管理" : "仅主家长"}}</text>
    </view>
    <view class="menu-item" bindtap="goHabitLibrary">
      <text>习惯库</text>
      <text class="muted-text">去添加</text>
    </view>
    <view class="menu-item" bindtap="goHabitManage">
      <text>习惯管理</text>
      <text class="muted-text">去管理</text>
    </view>
  </view>
</view>
