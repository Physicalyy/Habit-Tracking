.me-page {
  min-height: 100vh;
  padding: 0 24rpx 210rpx;
  padding-bottom: calc(210rpx + env(safe-area-inset-bottom));
}

.me-top {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 40;
  padding-left: 24rpx;
  padding-right: 24rpx;
  background: #f8faf8;
}

.me-top .nav-content {
  display: flex;
  align-items: center;
}

.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 36rpx;
  text-align: center;
}

.profile-section:active {
  opacity: 0.82;
}

.avatar-wrap {
  position: relative;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  color: #005d4c;
  background: #94f4d9;
  border-radius: 999rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.avatar-image {
  display: block;
  padding: 0;
  overflow: hidden;
  background: #e4e9e6;
}

.profile-name {
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.profile-info {
  flex: 1;
}

.profile-family {
  margin-top: 8rpx;
  color: #6e7a75;
  font-size: 26rpx;
  line-height: 38rpx;
}

.profile-family text {
  color: #006b58;
  font-weight: 700;
}

.child-card {
  margin-top: 32rpx;
  padding: 28rpx;
  border-left: 8rpx solid #006b58;
}

.child-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.child-left {
  display: flex;
  align-items: center;
  min-width: 0;
}

.child-avatar {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  overflow: hidden;
  color: #005d4c;
  background: rgba(118, 214, 188, 0.3);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.child-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.child-name {
  color: #191c1b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.child-desc {
  margin-top: 6rpx;
  color: #6e7a75;
  font-size: 24rpx;
  line-height: 34rpx;
}

.child-score {
  flex: none;
  margin-left: 18rpx;
  text-align: right;
}

.child-score-value {
  color: #735c00;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.child-score-label {
  margin-top: 2rpx;
  color: #6e7a75;
  font-size: 22rpx;
  line-height: 32rpx;
}

.family-section {
  margin-top: 32rpx;
}

.family-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.family-title {
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.family-role {
  margin-top: 4rpx;
  color: #006b58;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.family-members-card {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
  padding: 24rpx;
}

.member-bubble {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: #005d4c;
  background: #d9f7ee;
  border: 4rpx solid #76d6bc;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.member-copy {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.member-title {
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.member-desc {
  margin-top: 4rpx;
  color: #6e7a75;
  font-size: 24rpx;
  line-height: 34rpx;
}

.member-chevron {
  color: #a9b4af;
  font-size: 40rpx;
}

.bento-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 32rpx;
  margin-left: -10rpx;
  margin-right: -10rpx;
}

.bento-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 47.2%;
  min-height: 188rpx;
  margin: 10rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 107, 88, 0.05);
}

.bento-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
}

.bento-icon text {
  font-size: 48rpx;
  line-height: 1;
}

.bento-icon.primary {
  color: #006b58;
  background: #76d6bc;
}

.bento-icon.tertiary {
  color: #6d3f00;
  background: #ffddb0;
}

.bento-icon.secondary {
  color: #ffffff;
  background: #4f635d;
}

.bento-icon.neutral {
  color: #6e7a75;
  background: #e4e9e6;
}

.bento-text {
  color: #191c1b;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.menu-item-disabled {
  color: #9aa49f;
  opacity: 0.55;
}

.profile-dialog-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(25, 28, 27, 0.36);
}

.profile-dialog {
  width: 100%;
  max-width: 640rpx;
  padding: 36rpx 32rpx 30rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 60rpx rgba(25, 28, 27, 0.18);
}

.profile-dialog-title {
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.profile-dialog-desc {
  margin-top: 10rpx;
  color: #6e7a75;
  font-size: 25rpx;
  line-height: 36rpx;
  text-align: center;
}

.profile-avatar-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  min-height: 190rpx;
  margin: 30rpx auto 0;
  padding: 18rpx;
  color: #006b58;
  background: #eff8f4;
  border-radius: 24rpx;
  line-height: 1;
}

.profile-avatar-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  overflow: hidden;
  color: #005d4c;
  background: #94f4d9;
  border-radius: 999rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.profile-avatar-image {
  display: block;
}

.profile-avatar-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.profile-nickname-input {
  height: 88rpx;
  margin-top: 26rpx;
  padding: 0 24rpx;
  color: #191c1b;
  background: #f5f8f6;
  border: 2rpx solid #d8e5df;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 88rpx;
}

.profile-dialog-actions {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  margin-left: -10rpx;
  margin-right: -10rpx;
}

.profile-action {
  flex: 1;
  height: 88rpx;
  margin: 0 10rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.profile-action.secondary {
  color: #4f635d;
  background: #edf2ef;
}

.profile-action.primary {
  color: #ffffff;
  background: #006b58;
}
