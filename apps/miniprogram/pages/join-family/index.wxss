.join-page {
  padding: 0 24rpx 32rpx;
}

.join-hero {
  display: flex;
  justify-content: center;
  margin-top: 56rpx;
}

.join-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, #f4f0d8 0%, #e9f4ef 72%);
  border-radius: 999rpx;
}

.join-image {
  display: block;
  width: 292rpx;
  height: 292rpx;
}

.invite-card {
  margin-top: 46rpx;
}

.code-input {
  font-weight: 700;
  letter-spacing: 8rpx;
}

.code-icon {
  left: auto;
  right: 28rpx;
}

.join-info {
  background: #ffffff;
}

.scan-button {
  margin-top: 24rpx;
}

.join-action-spacer {
  height: 330rpx;
  height: calc(330rpx + env(safe-area-inset-bottom));
}

.visual-action {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 96rpx;
}

.visual-action-icon-left {
  margin-right: 12rpx;
  font-size: 34rpx;
  line-height: 1;
}

.action-disabled {
  opacity: 0.65;
}
