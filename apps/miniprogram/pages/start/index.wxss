.start-page {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
  padding: 0 40rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #ffffff 0%, #f8faf8 100%);
}

.brand-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 176rpx;
  padding: 88rpx 176rpx 0 40rpx;
  background: #f8faf8;
}

.brand-content {
  display: flex;
  align-items: center;
  flex: none;
  width: 300rpx;
  overflow: hidden;
}

.brand-symbol {
  flex: none;
  width: 54rpx;
  height: 54rpx;
  margin-right: 10rpx;
  color: #006b58;
  font-size: 54rpx;
  line-height: 54rpx;
}

.brand-name {
  color: #006b58;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
  white-space: nowrap;
}

.start-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: calc(100vh - 72rpx);
  padding-top: 200rpx;
  padding-bottom: 26rpx;
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
}

.hero-panel {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 74rpx;
}

.hero-blob {
  position: absolute;
  z-index: 0;
  border-radius: 999rpx;
  opacity: 0.2;
}

.primary-blob {
  top: -80rpx;
  left: -80rpx;
  width: 256rpx;
  height: 256rpx;
  background: #76d6bc;
}

.secondary-blob {
  right: -80rpx;
  bottom: -80rpx;
  width: 320rpx;
  height: 320rpx;
  background: #fcd664;
}

.hero-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 540rpx;
  padding: 32rpx;
  overflow: hidden;
  background: #ffffff;
  border: 2rpx solid rgba(225, 227, 225, 0.3);
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 107, 88, 0.06);
}

.float-animation {
  animation: start-float 6s ease-in-out infinite;
}

@keyframes start-float {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-30rpx);
  }
  100% {
    transform: translateY(0);
  }
}

.hero-image {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
}

.floating-chip {
  position: absolute;
  z-index: 3;
  display: flex;
  align-items: center;
  padding: 16rpx;
  color: #191c1b;
  background: #ffffff;
  border: 2rpx solid #eceeec;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(46, 49, 48, 0.16);
  font-size: 26rpx;
  font-weight: 500;
  line-height: 36rpx;
}

.growth-chip {
  top: 28rpx;
  right: -24rpx;
  transform: rotate(12deg);
}

.love-chip {
  left: -24rpx;
  bottom: 64rpx;
  transform: rotate(-6deg);
}

.chip-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  font-size: 34rpx;
  line-height: 34rpx;
}

.chip-image {
  display: block;
  flex: none;
}

.leaf-icon {
  color: #735c00;
}

.heart-icon {
  color: #006b58;
}

.start-copy {
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 44rpx;
  text-align: center;
}

.start-title {
  margin-bottom: 16rpx;
  color: #191c1b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 60rpx;
}

.start-subtitle {
  color: #006b58;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.start-desc {
  margin-top: 16rpx;
  color: #3e4945;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 44rpx;
}

.action-stack {
  width: 100%;
  max-width: 640rpx;
}

.start-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 112rpx;
  border-radius: 32rpx;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.create-button {
  color: #ffffff;
  background: #006b58;
  box-shadow: 0 8rpx 30rpx rgba(0, 107, 88, 0.15);
}

.join-button {
  margin-top: 24rpx;
  color: #006b58;
  background: transparent;
  border: 4rpx solid #006b58;
}

.tap-active {
  transform: scale(0.96);
  opacity: 0.9;
}

.button-icon {
  flex: none;
  width: 44rpx;
  height: 44rpx;
  margin-right: 10rpx;
  font-size: 44rpx;
  line-height: 44rpx;
}
