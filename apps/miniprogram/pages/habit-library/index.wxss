@import "/assets/fonts/material-symbols.wxss";

.habit-library-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: #f8faf8;
  color: #191c1b;
}

.library-header {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 112rpx;
  padding: 32rpx 40rpx 0;
  background: rgba(248, 250, 248, 0.92);
  border-bottom: 2rpx solid #eceeec;
}

.library-icon-button,
.library-header-spacer {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
}

.library-icon-button {
  color: #191c1b;
  font-size: 42rpx;
}

.library-title {
  color: #191c1b;
  font-size: 40rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.library-main {
  padding: 32rpx 40rpx 0;
}

.search-wrap {
  position: relative;
  display: flex;
  align-items: center;
  height: 96rpx;
}

.search-icon {
  position: absolute;
  left: 32rpx;
  z-index: 1;
  color: #6e7a75;
  font-size: 38rpx;
}

.search-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx 0 96rpx;
  color: #191c1b;
  background: #f2f4f2;
  border-radius: 24rpx;
  font-size: 30rpx;
}

.category-scroll {
  position: sticky;
  top: 112rpx;
  z-index: 40;
  width: 100%;
  margin: 32rpx -40rpx 0;
  padding: 0 40rpx 28rpx;
  background: #f8faf8;
  border-bottom: 2rpx solid #eceeec;
  white-space: nowrap;
}

.category-row {
  display: flex;
  align-items: center;
}

.category-pill {
  flex: none;
  margin-right: 16rpx;
  padding: 16rpx 32rpx;
  color: #3e4945;
  background: #eceeec;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 36rpx;
}

.category-active {
  color: #ffffff;
  background: #ff9d4d;
  font-weight: 700;
}

.library-state {
  margin-top: 48rpx;
  text-align: center;
}

.template-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-top: 32rpx;
}

.library-template-card {
  display: flex;
  width: 48.2%;
  min-height: 330rpx;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 32rpx 24rpx 24rpx;
  background: #ffffff;
  border-left: 8rpx solid #76d6bc;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 107, 88, 0.05);
  text-align: center;
}

.accent-secondary {
  border-left-color: #fcd664;
}

.accent-tertiary {
  border-left-color: #87ceeb;
}

.template-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 16rpx;
  background: rgba(118, 214, 188, 0.2);
  border-radius: 999rpx;
}

.icon-shell-secondary {
  background: rgba(252, 214, 100, 0.22);
}

.icon-shell-tertiary {
  background: rgba(135, 206, 235, 0.22);
}

.template-icon {
  color: #006b58;
  font-size: 56rpx;
}

.template-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
}

.icon-tone-secondary {
  color: #735c00;
}

.icon-tone-tertiary {
  color: #0c6780;
}

.template-name {
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 46rpx;
}

.template-desc {
  flex: 1;
  margin-top: 8rpx;
  color: #3e4945;
  font-size: 22rpx;
  line-height: 30rpx;
}

.template-age {
  margin-top: 16rpx;
  padding: 6rpx 18rpx;
  color: #3e4945;
  background: #f2f4f2;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 30rpx;
}

.template-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 64rpx;
  margin-top: 24rpx;
  color: #ffffff;
  background: #006b58;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 107, 88, 0.12);
}

.template-add-button-added {
  color: #006b58;
  background: rgba(0, 107, 88, 0.08);
  box-shadow: none;
}

.library-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
  padding: 56rpx 32rpx;
  color: #3e4945;
  background: #ffffff;
  border-radius: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 107, 88, 0.05);
}

.library-empty-icon {
  color: #006b58;
  font-size: 64rpx;
}

.library-empty-title {
  margin-top: 16rpx;
  color: #191c1b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.library-empty-desc {
  margin-top: 8rpx;
  color: #6e7a75;
  font-size: 24rpx;
  line-height: 34rpx;
}

.template-add-pressed,
.custom-button-pressed {
  transform: scale(0.96);
}

.add-icon {
  margin-right: 8rpx;
  font-size: 34rpx;
}

.custom-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 56rpx;
  padding: 48rpx 32rpx;
  color: #006b58;
  background: rgba(0, 107, 88, 0.05);
  border: 4rpx dashed #76d6bc;
  border-radius: 32rpx;
  text-align: center;
}

.custom-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  color: #ffffff;
  background: #006b58;
  border-radius: 999rpx;
  font-size: 48rpx;
}

.custom-title {
  margin-top: 16rpx;
  color: #006b58;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 46rpx;
}

.custom-desc {
  margin-top: 8rpx;
  color: #3e4945;
  font-size: 26rpx;
  line-height: 36rpx;
}

.custom-button {
  margin-top: 24rpx;
  padding: 20rpx 48rpx;
  color: #ffffff;
  background: #006b58;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 40rpx;
}
