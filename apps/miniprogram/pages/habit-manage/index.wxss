.habit-manage-page {
  padding-bottom: 56rpx;
}

.custom-action {
  flex: none;
  padding: 14rpx 22rpx;
  color: #ffffff;
  background: #006b58;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.manage-state {
  margin-top: 36rpx;
  text-align: center;
}

.empty-card {
  margin-top: 28rpx;
  padding: 36rpx;
}

.empty-title {
  color: #191c1b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.habit-list {
  margin-top: 28rpx;
}

.habit-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 26rpx;
}

.habit-icon {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: #006b58;
  background: #e6f7f1;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.habit-image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
}

.habit-main {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.habit-name {
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.habit-desc {
  margin-top: 6rpx;
  color: #56625d;
  font-size: 24rpx;
  line-height: 34rpx;
}

.habit-status {
  margin-top: 10rpx;
  color: #006b58;
  font-size: 24rpx;
  font-weight: 600;
}

.toggle-action {
  flex: none;
  margin-left: 18rpx;
  padding: 16rpx 22rpx;
  color: #006b58;
  background: #e6f7f1;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
}
