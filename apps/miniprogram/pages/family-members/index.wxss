.family-members-page {
  padding-bottom: 56rpx;
}

.invite-action {
  flex: none;
  padding: 14rpx 24rpx;
  color: #ffffff;
  background: #006b58;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.members-state {
  margin-top: 36rpx;
  text-align: center;
}

.empty-card {
  margin-top: 28rpx;
  padding: 36rpx;
}

.empty-title {
  color: #191c1b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.member-list {
  margin-top: 28rpx;
}

.member-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 28rpx;
}

.member-avatar {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: #005d4c;
  background: #dff7ee;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.member-main {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.member-name {
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.member-role {
  margin-top: 8rpx;
  color: #56625d;
  font-size: 24rpx;
  line-height: 34rpx;
}

.action-disabled {
  color: #a7b0ab;
  background: #eef1ef;
}
