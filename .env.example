TZ=Asia/Shanghai

MYSQL_DATABASE=habit_tracking
MYSQL_ROOT_PASSWORD=change-me
MYSQL_HOST_PORT=3306

BACKEND_HOST_PORT=18080
BACKEND_JAVA_OPTS=-Xms256m -Xmx512m
BACKEND_JRE_IMAGE=eclipse-temurin:17-jre

WECHAT_MINIPROGRAM_APPID=your-miniprogram-appid
WECHAT_MINIPROGRAM_SECRET=your-miniprogram-appsecret
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=604800

AVATAR_STORAGE_DIR=/app/data/avatars
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=2MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=2MB
